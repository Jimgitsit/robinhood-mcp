# Robinhood credentials
ROBINHOOD_USERNAME=your@email.com
ROBINHOOD_PASSWORD=yourpassword

# Optional: base32 TOTP secret from your authenticator app setup
# If set, logins use TOTP codes automatically (no mobile push required).
# To get this, re-enable 2FA in Robinhood and copy the "manual entry" key.
ROBINHOOD_TOTP_SECRET=
